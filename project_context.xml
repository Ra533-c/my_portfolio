        const closeModal = () => { modal.classList.add('invisible', 'opacity-0'); document.body.style.overflow = ''; setTimeout(() => { contactForm.reset(); modalFormView.classList.remove('hidden'); modalSuccessView.classList.add('hidden'); }, 300); };
        if(hireBtn) hireBtn.addEventListener('click', openModal); if(contactNavBtn) contactNavBtn.addEventListener('click', openModal); if(closeBtn) closeBtn.onclick = closeModal; if(successCloseBtn) successCloseBtn.onclick = closeModal; if(backdrop) backdrop.onclick = closeModal;
        if(contactForm) contactForm.addEventListener('submit', (e) => { e.preventDefault(); modalFormView.classList.add('hidden'); modalSuccessView.classList.remove('hidden'); modalSuccessView.classList.add('flex'); });
        window.addEventListener('keydown', (e) => { if(e.key === 'Escape') closeModal(); });
