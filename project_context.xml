          class="w-24 h-24 rounded-full border-4 border-primary/20 flex items-center justify-center mb-8 shadow-[0_0_30px_rgba(0,255,102,0.2)]">
          <span class="material-symbols-outlined text-6xl text-primary animate-pulse"
            data-weight="fill">check_circle</span>
        </div>
        <h2 class="font-display-lg text-headline-lg text-primary mb-4 tracking-tighter">MESSAGE SENT</h2>
        <p class="text-on-surface-variant font-body-lg max-w-xs mb-10">Thanks for reaching out. I'll get back to you
          within 24 hours.</p>
        <button
          class="w-full bg-[#1f1f1f] border border-[#00e55b]/30 text-white py-4 rounded-lg font-label-caps text-label-caps font-bold btn-transition shadow-lg"
          id="success-close-btn">BACK TO PORTFOLIO</button>
      </div>
    </div>
  </div>

  <!-- Silver Play Button Lightbox Modal -->
  <div class="fixed inset-0 z-[110] flex items-center justify-center invisible opacity-0 transition-all duration-300"
    id="silver-lightbox">
    <div class="absolute inset-0 bg-black/90 backdrop-blur-md" id="lightbox-backdrop"></div>
    <div class="relative w-full max-w-3xl mx-margin-mobile p-4 flex flex-col items-center z-10">
      <button class="absolute top-4 right-4 text-on-surface-variant hover:text-primary transition-colors z-20"
        id="close-lightbox">
        <span class="material-symbols-outlined text-3xl">close</span>
      </button>

      <div
        class="relative w-full aspect-[4/3] max-h-[70vh] flex items-center justify-center bg-black/50 border border-outline-variant/30 rounded-2xl overflow-hidden group">
        <!-- Prev Button -->
        <button
          class="absolute left-4 z-20 w-12 h-12 rounded-full bg-black/60 border border-outline-variant/30 text-white flex items-center justify-center hover:text-primary hover:border-primary transition-all active:scale-90"
          id="prev-lightbox-btn">
          <span class="material-symbols-outlined">chevron_left</span>
        </button>

        <img id="lightbox-img" class="max-w-full max-h-full object-contain transition-all duration-500" src=""
          alt="Silver Play Button Achievement">

        <!-- Next Button -->
        <button
          class="absolute right-4 z-20 w-12 h-12 rounded-full bg-black/60 border border-outline-variant/30 text-white flex items-center justify-center hover:text-primary hover:border-primary transition-all active:scale-90"
          id="next-lightbox-btn">
          <span class="material-symbols-outlined">chevron_right</span>
        </button>
      </div>

      <!-- Counter Indicator -->
      <p class="text-primary font-code text-code mt-4" id="lightbox-counter">IMAGE 1 OF 3</p>
    </div>
  </div>

  <!-- Toast Container -->
  <div id="toast-container" class="fixed bottom-8 right-8 z-[150] flex flex-col gap-4"></div>

  <script>
    // Global helper for Project "Read More" expanding
    window.toggleDesc = function (btn) {
      const p = btn.previousElementSibling;
      if (p.classList.contains('line-clamp-2')) {
        p.classList.remove('line-clamp-2');
        p.classList.add('line-clamp-none');
        btn.innerHTML = 'SHOW LESS <span class="material-symbols-outlined text-[12px]">expand_less</span>';
      } else {
        p.classList.remove('line-clamp-none');
        p.classList.add('line-clamp-2');
        btn.innerHTML = 'READ MORE <span class="material-symbols-outlined text-[12px]">expand_more</span>';
      }
      setTimeout(() => { if (window.ScrollTrigger) ScrollTrigger.refresh(); }, 100);
    };

    // Smooth scroll and standard intersection animation loader
    const revealObserver = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) entry.target.classList.add('active');
      });
    }, { threshold: 0.1, rootMargin: "0px 0px -50px 0px" });
    document.querySelectorAll('.reveal').forEach(el => revealObserver.observe(el));

    // Dynamic Variables State
    let projects = [];
    let silverImages = [];
    let silverActiveIndex = 0;

    // Elements Bindings
    const projectsContainer = document.getElementById('projects-container');
    const viewSilverBtn = document.getElementById('view-silver-btn');
    const silverLightbox = document.getElementById('silver-lightbox');
    const lightboxImg = document.getElementById('lightbox-img');
    const lightboxCounter = document.getElementById('lightbox-counter');
    const prevLightboxBtn = document.getElementById('prev-lightbox-btn');
    const nextLightboxBtn = document.getElementById('next-lightbox-btn');
    const closeLightboxBtn = document.getElementById('close-lightbox');
    const lightboxBackdrop = document.getElementById('lightbox-backdrop');

    const contactForm = document.getElementById('contact-form');
    const modalFormView = document.getElementById('modal-form-view');
    const modalSuccessView = document.getElementById('modal-success-view');
    const contactModal = document.getElementById('contact-modal');
    const hireBtn = document.getElementById('nav-hire-me');
    const contactNavBtn = document.getElementById('nav-contact-link');
    const closeModalBtn = document.getElementById('close-modal');
    const successCloseBtn = document.getElementById('success-close-btn');
    const modalBackdrop = document.getElementById('modal-backdrop');
    const downloadCvBtn = document.getElementById('download-cv-btn');

    // Custom Toast Alert System
    const showToast = (message, type = 'error') => {
      const container = document.getElementById('toast-container');
      const toast = document.createElement('div');
      toast.className = `px-6 py-4 rounded-xl border backdrop-blur-md shadow-lg transition-all duration-300 transform translate-y-2 opacity-0 flex items-center gap-3 ${type === 'success'
        ? 'bg-black/90 border-primary text-primary shadow-[0_0_15px_rgba(0,255,102,0.15)]'
        : 'bg-black/90 border-red-500/50 text-red-400 shadow-[0_0_15px_rgba(239,68,68,0.15)]'
        }`;

      const icon = type === 'success' ? 'check_circle' : 'error';
      toast.innerHTML = `
        <span class="material-symbols-outlined text-xl">${icon}</span>
        <span class="font-code text-sm">${message}</span>
      `;

      container.appendChild(toast);

      // Animation entry trigger
      setTimeout(() => {
        toast.classList.remove('translate-y-2', 'opacity-0');
      }, 10);

      // Auto dismiss
      setTimeout(() => {
        toast.classList.add('translate-y-2', 'opacity-0');
        setTimeout(() => {
          toast.remove();
        }, 300);
      }, 4000);
    };

    // Swiper bindings and state
    let activeSkillIndex = 0;
    let activeProjectIndex = 0;

    const skillCards = document.querySelectorAll('.skills-category-card');
    const skillsSwiperCtrl = document.getElementById('skills-swiper-ctrl');
    const skillsPrevBtn = document.getElementById('skills-prev-btn');
    const skillsNextBtn = document.getElementById('skills-next-btn');
    const skillsSwiperTitle = document.getElementById('skills-swiper-title');
    const skillsSwiperPage = document.getElementById('skills-swiper-page');

    const projectsPrevBtn = document.getElementById('projects-prev-btn');
    const projectsNextBtn = document.getElementById('projects-next-btn');
    const projectsSwiperCtrl = document.getElementById('projects-swiper-ctrl');
    const projectsSwiperTitle = document.getElementById('projects-swiper-title');
    const projectsSwiperPage = document.getElementById('projects-swiper-page');

    const updateSkillsSwiper = () => {
      const isMobileTablet = window.innerWidth < 1024;
      if (isMobileTablet) {
        skillsSwiperCtrl.classList.remove('hidden');
        skillsSwiperCtrl.classList.add('flex');
        skillCards.forEach((card, idx) => {
          if (idx === activeSkillIndex) {
            card.style.display = 'block';
            card.classList.remove('lg:col-span-3');
            gsap.fromTo(card, { opacity: 0, y: 15 }, { opacity: 1, y: 0, duration: 0.4, ease: "power2.out" });
          } else {
            card.style.display = 'none';
          }
        });
        const titles = [
          "Languages & Frontend",
          "Backend & Databases",
          "DevOps & Messaging",
          "Tools, Payments & Others"
        ];
        skillsSwiperTitle.textContent = titles[activeSkillIndex];
        skillsSwiperPage.textContent = `${activeSkillIndex + 1} / ${skillCards.length}`;
      } else {
        skillsSwiperCtrl.classList.remove('flex');
        skillsSwiperCtrl.classList.add('hidden');
        skillCards.forEach((card, idx) => {
          card.style.display = 'block';
          if (idx === 3) {
            card.classList.add('lg:col-span-3');
          } else {
            card.classList.remove('lg:col-span-3');
          }
        });
      }
    };

    const updateProjectsView = () => {
      const isMobileTablet = window.innerWidth < 768;
      const cards = projectsContainer.querySelectorAll('.project-card');
      if (cards.length === 0) return;

      if (isMobileTablet) {
        projectsSwiperCtrl.classList.remove('hidden');
        projectsSwiperCtrl.classList.add('flex');
        cards.forEach((card, idx) => {
          if (idx === activeProjectIndex) {
            card.style.display = 'block';
            gsap.fromTo(card, { opacity: 0, y: 15 }, { opacity: 1, y: 0, duration: 0.4, ease: "power2.out" });
          } else {
            card.style.display = 'none';
          }
        });
        if (projects[activeProjectIndex]) {
          projectsSwiperTitle.textContent = projects[activeProjectIndex].title;
          projectsSwiperPage.textContent = `${activeProjectIndex + 1} / ${projects.length}`;
        }
      } else {
        projectsSwiperCtrl.classList.remove('flex');
        projectsSwiperCtrl.classList.add('hidden');
        cards.forEach(card => {
          card.style.display = 'block';
        });
      }
    };

    if (skillsPrevBtn) {
      skillsPrevBtn.addEventListener('click', () => {
        activeSkillIndex = (activeSkillIndex - 1 + skillCards.length) % skillCards.length;
        updateSkillsSwiper();
      });
    }
    if (skillsNextBtn) {
      skillsNextBtn.addEventListener('click', () => {
        activeSkillIndex = (activeSkillIndex + 1) % skillCards.length;
        updateSkillsSwiper();
      });
    }

    if (projectsPrevBtn) {
      projectsPrevBtn.addEventListener('click', () => {
        if (projects.length === 0) return;
        activeProjectIndex = (activeProjectIndex - 1 + projects.length) % projects.length;
        updateProjectsView();
      });
    }
    if (projectsNextBtn) {
      projectsNextBtn.addEventListener('click', () => {
        if (projects.length === 0) return;
        activeProjectIndex = (activeProjectIndex + 1) % projects.length;
        updateProjectsView();
      });
    }

    window.addEventListener('resize', () => {
      updateSkillsSwiper();
      updateProjectsView();
    });

    // Load Projects API
    const loadProjects = async () => {
      try {
        const res = await fetch('/api/projects');
        if (!res.ok) throw new Error('API Error');
        projects = await res.json();
        renderProjects();
      } catch (err) {
        console.error('Failed to load projects:', err);
        projectsContainer.innerHTML = `
          <div class="col-span-full text-center py-12 border border-red-500/30 rounded-2xl bg-red-950/10">
            <span class="material-symbols-outlined text-5xl text-red-400 mb-2">error</span>
            <p class="text-red-400 font-code">FAILED TO LOAD PROJECTS. PLEASE REFRESH THE PAGE.</p>
          </div>
        `;
        showToast('Failed to connect to the backend server to fetch projects.', 'error');
      }
    };

    // Render Dynamic Cards
    const renderProjects = () => {
      if (projects.length === 0) {
        projectsContainer.innerHTML = `
          <div class="col-span-full text-center py-12">
            <p class="text-on-surface-variant font-code">NO PROJECTS FOUND.</p>
          </div>
        `;
        return;
      }

      projectsContainer.innerHTML = projects.map(proj => `
        <div class="project-card border border-outline-variant/30 rounded-2xl overflow-hidden bg-surface-container-low group relative">
          <div class="aspect-video relative overflow-hidden bg-surface-container-high">
            <img alt="${proj.title} Mockup" class="project-card-img w-full h-full object-cover grayscale hover:grayscale-0 hover:scale-110 transition-all duration-700" src="${proj.imageUrl}" loading="lazy">
            <div class="absolute top-4 right-4 bg-primary text-black px-3 py-1 rounded-full font-label-caps text-label-caps font-bold pointer-events-none">
              ${proj.techStack[0] || 'DEV'}
            </div>
          </div>
          <div class="p-8">
            <h3 class="font-headline-md text-headline-md text-on-surface mb-2">${proj.title}</h3>
            <div class="mb-6">
              <p class="text-on-surface-variant text-sm line-clamp-2 transition-all duration-300 leading-relaxed">${proj.description}</p>
              ${proj.description.length > 100 ? `<button type="button" onclick="window.toggleDesc(this)" class="read-more-btn text-primary text-[10px] font-label-caps tracking-widest hover:underline mt-2 flex items-center gap-1 uppercase relative z-10">READ MORE <span class="material-symbols-outlined text-[12px]">expand_more</span></button>` : ''}
            </div>
            <div class="flex flex-wrap gap-2 mb-6">
              ${proj.techStack.map(tech => `
                <span class="bg-surface-container px-3 py-1 rounded text-primary font-code text-code">${tech}</span>
              `).join('')}
            </div>
            <div class="flex gap-4">
              <a href="${proj.liveLink}" target="_blank" rel="noopener noreferrer" class="bg-[#1f1f1f]/80 backdrop-blur-md border border-[#00e55b]/30 text-white px-5 py-2 rounded-full font-label-caps text-[11px] font-bold btn-transition shadow-md relative z-10">LIVE DEMO</a>
            </div>
          </div>
        </div>
      `).join('');
      updateProjectsView();

      // Execute scroll animation for dynamically loaded project cards
      setTimeout(() => {
        if (window.ScrollTrigger) ScrollTrigger.refresh();
        gsap.from("#projects-container .project-card", {
          scrollTrigger: {
            trigger: "#work",
            start: "top 80%",
            toggleActions: "play none none none"
          },
          duration: 0.8,
          opacity: 0,
          y: 40,
          stagger: 0.15,
          ease: "power2.out",
          clearProps: "all",
          onComplete: () => {
            document.querySelectorAll("#projects-container .project-card").forEach(card => card.classList.add('project-animate-ready'));
          }
        });
      }, 200);
    };

    // Load Silver images
    const loadSilverImages = async () => {
      try {
        const res = await fetch('/api/silver');
        if (!res.ok) throw new Error('API Error');
        silverImages = await res.json();
      } catch (err) {
        console.error('Failed to load Silver images:', err);
        silverImages = [
          "https://res.cloudinary.com/dkzzbjfb2/image/upload/v1779541245/IMG_20250905_153755.jpg_d1httd.jpg",
          "https://res.cloudinary.com/dkzzbjfb2/image/upload/v1779541244/IMG_20250905_153737.jpg_hymwkp.jpg",
          "https://res.cloudinary.com/dkzzbjfb2/image/upload/v1779541245/IMG_20250905_152723.jpg_zb8sjg.jpg"
        ];
      }
    };

    // Lightbox handlers
    const openLightbox = () => {
      if (silverImages.length === 0) return;
      silverActiveIndex = 0;
      updateLightboxImage();
      silverLightbox.classList.remove('invisible', 'opacity-0');
      document.body.style.overflow = 'hidden';
    };

    const closeLightbox = () => {
      silverLightbox.classList.add('invisible', 'opacity-0');
      document.body.style.overflow = '';
    };

    const updateLightboxImage = () => {
      lightboxImg.style.opacity = 0;
      setTimeout(() => {
        lightboxImg.src = silverImages[silverActiveIndex];
        lightboxCounter.textContent = `IMAGE ${silverActiveIndex + 1} OF ${silverImages.length}`;
        lightboxImg.style.opacity = 1;
      }, 200);
    };

    const prevImage = () => {
      silverActiveIndex = (silverActiveIndex - 1 + silverImages.length) % silverImages.length;
      updateLightboxImage();
    };

    const nextImage = () => {
      silverActiveIndex = (silverActiveIndex + 1) % silverImages.length;
      updateLightboxImage();
    };

    if (viewSilverBtn) viewSilverBtn.addEventListener('click', openLightbox);
    if (closeLightboxBtn) closeLightboxBtn.addEventListener('click', closeLightbox);
    if (lightboxBackdrop) lightboxBackdrop.addEventListener('click', closeLightbox);
    if (prevLightboxBtn) prevLightboxBtn.addEventListener('click', prevImage);
    if (nextLightboxBtn) nextLightboxBtn.addEventListener('click', nextImage);

    // Modal forms controls
    const openModal = (e) => {
      if (e) e.preventDefault();
      modalFormView.classList.remove('hidden');
      modalSuccessView.classList.add('hidden');
      modalSuccessView.classList.remove('flex');
      contactModal.classList.remove('invisible', 'opacity-0');
      document.body.style.overflow = 'hidden';
    };

    const closeModal = () => {
      contactModal.classList.add('invisible', 'opacity-0');
      document.body.style.overflow = '';
      setTimeout(() => {
        contactForm.reset();
        modalFormView.classList.remove('hidden');
        modalSuccessView.classList.add('hidden');
      }, 300);
    };

    const ctaContactBtn = document.getElementById('cta-contact-btn');
    if (hireBtn) hireBtn.addEventListener('click', openModal);
    if (contactNavBtn) contactNavBtn.addEventListener('click', openModal);
    if (ctaContactBtn) ctaContactBtn.addEventListener('click', openModal);
    if (closeModalBtn) closeModalBtn.onclick = closeModal;
    if (successCloseBtn) successCloseBtn.onclick = closeModal;
    if (modalBackdrop) modalBackdrop.onclick = closeModal;

    // GSAP Animations
    const initAnimations = () => {
      // Register ScrollTrigger plugin
      gsap.registerPlugin(ScrollTrigger);

      // Nav Bar Animation
      gsap.from("nav", {
        duration: 1,
        y: -100,
        opacity: 0,
        ease: "power4.out"
      });

      // Hero Name and texts
      gsap.from(".hero-text", {
        duration: 1.2,
        opacity: 0,
        y: 30,
        ease: "power4.out",
        delay: 0.4,
        clearProps: "all"
      });

      gsap.from(".hero-side-left h3, .hero-side-left p", {
        duration: 1,
        opacity: 0,
        y: 30,
        delay: 0.4,
        stagger: 0.15,
        ease: "power3.out"
      });

      gsap.from(".hero-side-right h3, .hero-side-right p", {
        duration: 1,
        opacity: 0,
        y: 30,
        delay: 0.4,
        stagger: 0.15,
        ease: "power3.out"
      });

      // Hero Portrait Animation
      gsap.from(".hero-photo", {
        duration: 1.2,
        scale: 0.85,
        opacity: 0,
        y: 40,
        ease: "back.out(1.5)",
        delay: 0.2,
        clearProps: "all",
        onComplete: () => {
          const heroGroup = document.getElementById('hero-center-group');
          if (heroGroup) heroGroup.classList.add('hero-animate-ready');
        }
      });

      // Hero Tech Icons Animation
      gsap.from("main section:first-of-type .material-symbols-outlined", {
        duration: 1,
        opacity: 0,
        y: 30,
        delay: 0.6,
        stagger: 0.15,
        ease: "power3.out"
      });

      // Philosophy Section Heading
      gsap.from("#philosophy h2", {
        scrollTrigger: {
          trigger: "#philosophy h2",
          start: "top 85%",
          toggleActions: "play none none none"
        },
        duration: 1,
        y: 40,
        opacity: 0,
        ease: "power3.out"
      });

      // Philosophy Section hover-cards
      gsap.from(".glass-panel.hover-card", {
        scrollTrigger: {
          trigger: ".glass-panel.hover-card",
          start: "top 90%",
          toggleActions: "play none none none"
        },
        duration: 1,
        y: 50,
        opacity: 0,
        stagger: 0.15,
        ease: "power3.out"
      });

      // Tech Arsenal Heading Animation
      gsap.from("#stack-heading", {
        scrollTrigger: {
          trigger: "#stack-heading",
          start: "top 85%",
          toggleActions: "play none none none"
        },
        duration: 1,
        y: 40,
        opacity: 0,
        ease: "power3.out"
      });

      // Tech Arsenal Stagger scroll animation
      gsap.from(".skills-category-card", {
        scrollTrigger: {
          trigger: "#stack",
          start: "top 80%",
          toggleActions: "play none none none"
        },
        duration: 0.8,
        opacity: 0,
        y: 40,
        stagger: 0.15,
        ease: "power2.out"
      });

      // Stagger animation for individual skill badges inside each category card on scroll
      document.querySelectorAll(".skills-category-card").forEach(card => {
        gsap.from(card.querySelectorAll(".skill-badge"), {
          scrollTrigger: {
            trigger: card,
            start: "top 85%",
            toggleActions: "play none none none"
          },
          duration: 0.6,
          opacity: 0,
          scale: 0.8,
          y: 15,
          stagger: 0.04,
          ease: "back.out(1.7)",
          clearProps: "all",
          onComplete: () => card.classList.add('skills-animate-ready')
        });
      });

      // Featured Projects Header Animation
      gsap.from("#work h2, #work p", {
        scrollTrigger: {
          trigger: "#work h2",
          start: "top 85%",
          toggleActions: "play none none none"
        },
        duration: 1,
        opacity: 0,
        y: 40,
        stagger: 0.15,
        ease: "power3.out"
      });

      // Journey Section Heading Animation
      gsap.from("#journey h2", {
        scrollTrigger: {
          trigger: "#journey h2",
          start: "top 85%",
          toggleActions: "play none none none"
        },
        duration: 1,
        opacity: 0,
        y: 40,
        ease: "power3.out"
      });

      // Journey Section Timeline Entry Animation
      document.querySelectorAll(".journey-item").forEach(item => {
        gsap.from(item, {
          scrollTrigger: {
            trigger: item,
            start: "top 85%",
            toggleActions: "play none none none"
          },
          duration: 1,
          opacity: 0,
          y: 35,
          ease: "power3.out"
        });
      });

      // Silver Play button card zoom in
      gsap.from(".award-card", {
        scrollTrigger: {
          trigger: ".award-card",
          start: "top 85%",
          toggleActions: "play none none none"
        },
        duration: 1.2,
        scale: 0.95,
        opacity: 0,
        y: 45,
        ease: "back.out(1.5)"
      });

      // Contact section elements staggered fade & rise
      gsap.from("#contact h2, #contact p, #contact .flex.flex-wrap", {
        scrollTrigger: {
          trigger: "#contact",
          start: "top 85%",
          toggleActions: "play none none none"
        },
        duration: 0.8,
        opacity: 0,
        y: 40,
        stagger: 0.15,
        ease: "power3.out",
        clearProps: "all"
      });

      // Footer elements staggered fade & rise
      gsap.from("footer > div, footer > p", {
        scrollTrigger: {
          trigger: "footer",
          start: "top 90%",
          toggleActions: "play none none none"
        },
        duration: 0.8,
        opacity: 0,
        y: 40,
        stagger: 0.15,
        ease: "power3.out",
        clearProps: "all"
      });
    };

    // Contact API dispatcher
    if (contactForm) {
      contactForm.addEventListener('submit', async (e) => {
        e.preventDefault();

        const textInputs = contactForm.querySelectorAll('input[type="text"]');
        const nameInput = textInputs[0];
        const emailInput = contactForm.querySelector('input[type="email"]');
        const subjectInput = textInputs[1];
        const messageInput = contactForm.querySelector('textarea');
        const submitBtn = contactForm.querySelector('button[type="submit"]');

        const payload = {
          name: nameInput.value,
          email: emailInput.value,
          subject: subjectInput.value,
          message: messageInput.value
        };

        if (payload.name.trim().length < 2 || payload.subject.trim().length < 2 || payload.message.trim().length < 10) {
          showToast('Validation Error: Name & Subject must be 2+ chars, Message 10+ chars.', 'error');
          return;
        }

        try {
          submitBtn.disabled = true;
          submitBtn.innerHTML = '<span class="material-symbols-outlined animate-spin text-lg">progress_activity</span> SENDING...';
          submitBtn.style.opacity = 0.7;
          submitBtn.classList.add('cursor-not-allowed');

          const res = await fetch('/api/contact', {
            method: 'POST',
            headers: {
              'Content-Type': 'application/json'
            },
            body: JSON.stringify(payload)
          });

          const data = await res.json();

          if (!res.ok) {
            throw new Error(data.error || 'Server Error');
          }

          modalFormView.classList.add('hidden');
          modalSuccessView.classList.remove('hidden');
          modalSuccessView.classList.add('flex');
          showToast('Message sent successfully!', 'success');
          contactForm.reset();
        } catch (err) {
          console.error(err);
          showToast(err.message || 'Failed to send message. Please try again.', 'error');
        } finally {
          submitBtn.disabled = false;
          submitBtn.innerHTML = 'SEND MESSAGE';
          submitBtn.style.opacity = 1;
          submitBtn.classList.remove('cursor-not-allowed');
        }
      });
    }

    // Download CV handler with "Coming soon" fallback alert
    if (downloadCvBtn) {
      downloadCvBtn.addEventListener('click', async (e) => {
        e.preventDefault();
        try {
          const response = await fetch('/SDE_Resume.pdf', { method: 'HEAD' });
          if (response.ok) {
            const link = document.createElement('a');
            link.href = '/SDE_Resume.pdf';
            link.download = 'Rajnikant_SDE_Resume.pdf';
            document.body.appendChild(link);
            link.click();
            document.body.removeChild(link);
          } else {
            showToast('CV will be available soon', 'error');
          }
        } catch (err) {
          showToast('CV will be available soon', 'error');
        }
      });
    }

    // Initialize application on loaded
    window.addEventListener('DOMContentLoaded', () => {
      loadProjects();
      loadSilverImages();
      updateSkillsSwiper();
      initAnimations();
    });

    // Keyboard handlers
    window.addEventListener('keydown', (e) => {
      if (!silverLightbox.classList.contains('invisible')) {
        if (e.key === 'Escape') closeLightbox();
        if (e.key === 'ArrowLeft') prevImage();
        if (e.key === 'ArrowRight') nextImage();
      }
      if (e.key === 'Escape') closeModal();
    });
  </script>
</body>

</html>
