  <style>
    body {
      background-color: #0e0e0e;
      color: #e2e2e2;
      overflow-x: hidden;
      position: relative;
    }

    .mesh-bg {
      position: fixed;
      top: 0;
      left: 0;
      width: 100%;
      height: 100%;
      z-index: -1;
      background-color: #0e0e0e;
      background-image:
        radial-gradient(at 0% 0%, hsla(142, 100%, 15%, 0.1) 0px, transparent 50%),
        radial-gradient(at 100% 0%, hsla(142, 100%, 15%, 0.05) 0px, transparent 50%),
        radial-gradient(at 100% 100%, hsla(142, 100%, 15%, 0.05) 0px, transparent 50%),
        radial-gradient(at 0% 100%, hsla(142, 100%, 15%, 0.1) 0px, transparent 50%);
      animation: mesh-move 20s ease infinite alternate;
    }

    @keyframes mesh-move {
      0% {
        opacity: 0.5;
        transform: scale(1);
      }

      100% {
        opacity: 0.8;
        transform: scale(1.1);
      }
    }

    .emerald-glow {
      text-shadow: 0 0 12px rgba(0, 229, 91, 0.6);
    }

    .aura-pulse {
      animation: aura-pulse 3s infinite ease-in-out;
    }

    @keyframes aura-pulse {

      0%,
      100% {
        text-shadow: 0 0 10px rgba(0, 255, 102, 0.4), 0 0 20px rgba(0, 255, 102, 0.2);
      }

      50% {
        text-shadow: 0 0 20px rgba(0, 255, 102, 0.8), 0 0 40px rgba(0, 255, 102, 0.4);
      }
    }

    .glass-panel {
      background: rgba(31, 31, 31, 0.4);
      backdrop-filter: blur(12px);
      border: 1px solid rgba(59, 75, 58, 0.2);
    }

    .hover-card:hover {
      transform: translateY(-8px);
      border-color: #00ff66;
      box-shadow: 0 10px 40px -10px rgba(0, 255, 102, 0.25);
    }

    .timeline-dot {
      box-shadow: 0 0 10px #00e55b;
    }

    .reveal {
      opacity: 0;
      transform: translateY(30px);
      transition: all 0.8s cubic-bezier(0.215, 0.61, 0.355, 1);
    }

    .reveal.active {
      opacity: 1;
      transform: translateY(0);
    }

    @media (prefers-reduced-motion: reduce) {

      .reveal,
      .hover-card,
      .project-card,
      .aura-pulse,
      .mesh-bg,
      .btn-transition {
        animation: none !important;
        transition: none !important;
        transform: none !important;
        opacity: 1 !important;
      }
    }

    ::-webkit-scrollbar {
      width: 6px;
    }

    ::-webkit-scrollbar-track {
      background: #0e0e0e;
    }

    ::-webkit-scrollbar-shadow {
      box-shadow: none;
    }

    ::-webkit-scrollbar-thumb {
      background: #353535;
      border-radius: 10px;
    }

    ::-webkit-scrollbar-thumb:hover {
      background: #00e55b;
    }

    .btn-transition {
      position: relative;
      overflow: hidden;
      transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
      z-index: 1;
    }

    .btn-transition:hover {
      transform: translateY(-3px) scale(1.05);
      background-color: #00ff66 !important;
      border-color: #00ff66 !important;
      color: #000000 !important;
      box-shadow: 0 0 20px rgba(0, 255, 102, 0.5) !important;
    }

    .btn-transition:active {
      transform: translateY(0) scale(0.98) !important;
    }

    .btn-transition::before {
      content: '';
      position: absolute;
      top: 0;
      left: -100%;
      width: 100%;
      height: 100%;
      background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.4), transparent);
      transition: left 0.6s ease;
      z-index: -1;
    }

    .btn-transition:hover::before {
      left: 100%;
    }

    .skill-badge {
      background: rgba(31, 31, 31, 0.65);
      backdrop-filter: blur(12px);
      border: 1px solid rgba(0, 255, 102, 0.25);
      color: #ffffff;
      font-weight: 500;
      transition: background-color 0.3s, border-color 0.3s, color 0.3s, box-shadow 0.3s;
      position: relative;
      overflow: hidden;
      border-radius: 12px;
      cursor: pointer;
    }

    .skills-animate-ready .skill-badge {
      transition: background-color 0.3s, border-color 0.3s, color 0.3s, box-shadow 0.3s, transform 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    }

    .skill-badge:hover {
      transform: translateY(-3px) scale(1.05);
      border-color: #00ff66;
      box-shadow: 0 0 20px rgba(0, 255, 102, 0.5);
      background: #00ff66;
      color: #000000;
    }

    .skill-badge::before {
      content: '';
      position: absolute;
      top: 0;
      left: -100%;
      width: 100%;
      height: 100%;
      background: linear-gradient(90deg,
          transparent,
          rgba(255, 255, 255, 0.3),
          transparent);
      transition: 0.6s ease;
    }

    .skill-badge:hover::before {
      left: 100%;
